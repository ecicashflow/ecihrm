# ─────────────────────────────────────────────────────────────
# ECI HRM — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` for local development, or set these
# variables in your Vercel project settings for production.
# NEVER commit the real `.env` file.

# ── Database (Neon Postgres) ──────────────────────────────────
# Pooled connection string (used by the app at runtime).
# On Neon: this is the "-pooler" endpoint.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public&pgbouncer=true"

# Direct (non-pooled) connection string (used by Prisma migrations).
# On Neon: this is the regular (non-pooler) endpoint.
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

# ── Auth / Sessions ───────────────────────────────────────────
# Secret used to sign session JWTs. Generate with:
#   openssl rand -base64 32
JWT_SECRET="replace-with-a-32+-char-random-string"

# ── AI Features (OpenAI) ──────────────────────────────────────
# Required for the "AI Analysis" buttons on appraisal forms and
# cycle summary reports. If omitted, AI routes return 503 and the
# rest of the app continues to work normally.
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# ── Production Admin Seed (optional) ──────────────────────────
# Used by `bun run db:seed` to create the initial admin account.
# If omitted, sensible defaults are used (see prisma/seed.ts).
ADMIN_EMAIL="imunir@eci.com.pk"
ADMIN_NAME="Muhammad Unir"
ADMIN_PASSWORD="ECI@dm1n#2025!Secure"
ADMIN_EMPLOYEE_ID="ECI-001"
